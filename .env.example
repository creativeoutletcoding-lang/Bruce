# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role — server-side only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — server-side only, NEVER expose to client
ANTHROPIC_API_KEY=sk-ant-...

# Firebase Cloud Messaging — used for push notifications
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-public-key

# Google OAuth — required for Drive and Calendar integrations
# Get these from Google Cloud Console → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs must include: https://your-project.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App URL — used for OAuth redirects
# Dev: http://localhost:3000  |  Prod: https://heybruce.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin access — user with this email gets role='admin' on first login
ADMIN_EMAIL=your-admin-email@gmail.com

# Google Calendar — shared family calendar
# FAMILY_CALENDAR_REFRESH_TOKEN: long-lived refresh token for the johnson2016family@gmail.com account.
#   Get it by running the one-time OAuth flow for that account with calendar scope.
# FAMILY_CALENDAR_ID: the calendar ID — usually "primary" for the primary calendar,
#   or the full email address (johnson2016family@gmail.com) if that account has one primary calendar.
FAMILY_CALENDAR_REFRESH_TOKEN=your-family-calendar-refresh-token
FAMILY_CALENDAR_ID=primary
# Timezone for timed events — must be a valid IANA tz name (e.g. America/New_York, America/Chicago)
FAMILY_CALENDAR_TIMEZONE=America/Chicago
